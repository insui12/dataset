# PostgreSQL connection
GBTD_DATABASE_URL=postgresql+psycopg://gbtd:gbtd@127.0.0.1:5432/gbtd

# Worker runtime
GBTD_RUNNER_ID=worker-1
GBTD_CONCURRENCY=4
GBTD_LEASE_SECONDS=900
GBTD_VISIBILITY_TIMEOUT_SECONDS=1200
GBTD_MANIFEST_PATH=manifests/sample.manifest.yaml

# HTTP / retry policy
GBTD_HOST_CONCURRENCY=4
GBTD_PER_HOST_RPS=1.0
GBTD_RATE_BUCKET_BURST=6
GBTD_RETRY_BASE_SECONDS=10
GBTD_RETRY_MAX_SECONDS=180
GBTD_RETRY_JITTER=0.35
GBTD_TIMEOUT_SECONDS=20
GBTD_USER_AGENT=GBTD-Collector/0.1 (+research)

# Optional API tokens (family specific)
GBTD_GITHUB_TOKEN=
GBTD_GITLAB_TOKEN=
GBTD_JIRA_TOKEN=
GBTD_LAUNCHPAD_TOKEN=
GBTD_REDMINE_TOKEN=
GBTD_YOUTRACK_TOKEN=
GBTD_GOOGLE_TOKEN=
GBTD_DEBIAN_TOKEN=
